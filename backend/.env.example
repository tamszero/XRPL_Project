# Gemini API 설정
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=your_gemini_api_key_here

# ngrok 설정 (선택사항)
# https://dashboard.ngrok.com/auth/your-authtoken 에서 확인
NGROK_TOKEN=your_ngrok_token_here

# XRPL 설정
XRPL_NETWORK_URL=https://s.altnet.rippletest.net:51234

# 데이터베이스 설정
DATABASE_URL=sqlite:///./finance_compass.db

# 서버 설정
PORT=8000
HOST=0.0.0.0
